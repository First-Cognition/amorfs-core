# Business card example from the Amorfs specification

business card [
  Alan Turing
  - role [mathematician {en} | mathématicien {fr}]
  - contact [
    - email [alan@turing.com]
    - phone [07949 212255]
  ]
  - address [
    - street {en} | rue {fr} [Bletchley Park]
    - city [Buckinghamshire]
  ]
]
